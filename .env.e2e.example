# Copy this file to `.env.e2e.local` to override E2E targets on your machine.

# Global override for all E2E tests.
# E2E_MAP_URL=https://nostra.earthmc.net/

# Override only the planning test target.
# E2E_PLANNING_MAP_URL=https://nostra.earthmc.net/

# Override only the archive test target.
# Leave this on the regular EarthMC map unless you intentionally want archive
# coverage against a different host.
# E2E_ARCHIVE_MAP_URL=https://map.earthmc.net/
