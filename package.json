{
  "name": "earthmc-dynmap-plus",
  "private": true,
  "type": "module",
  "scripts": {
    "userscript": "node build-userscript.js",
    "extension": "node build-extension.js",
    "extension:chromium": "node build-extension.js chromium",
    "extension:firefox": "node build-extension.js firefox",
    "build": "npm run userscript && npm run extension",
    "convert:borders:nostra": "node scripts/convert-borders-geojson.mjs",
    "test:e2e": "node scripts/e2e/run.mjs",
    "test:e2e:all": "npm run test:e2e",
    "test:e2e:firefox": "node scripts/e2e/run.mjs --browser firefox",
    "test:e2e:chromium": "node scripts/e2e/run.mjs --browser chromium",
    "test:e2e:archive": "node scripts/e2e/run.mjs --test archive",
    "test:e2e:archive:firefox": "node scripts/e2e/run.mjs --browser firefox --test archive",
    "test:e2e:archive:chromium": "node scripts/e2e/run.mjs --browser chromium --test archive",
    "test:e2e:planning": "node scripts/e2e/run.mjs --test planning",
    "test:e2e:planning:firefox": "node scripts/e2e/run.mjs --browser firefox --test planning",
    "test:e2e:planning:chromium": "node scripts/e2e/run.mjs --browser chromium --test planning",
    "test:e2e:planning-calibration": "node scripts/e2e/run.mjs --test planning-calibration",
    "test:e2e:planning-calibration:firefox": "node scripts/e2e/run.mjs --browser firefox --test planning-calibration",
    "test:e2e:planning-calibration:chromium": "node scripts/e2e/run.mjs --browser chromium --test planning-calibration",
    "test:e2e:planning-projection": "node scripts/e2e/run.mjs --test planning-projection",
    "test:e2e:planning-projection:firefox": "node scripts/e2e/run.mjs --browser firefox --test planning-projection",
    "test:e2e:planning-projection:chromium": "node scripts/e2e/run.mjs --browser chromium --test planning-projection",
    "test:e2e:planning-preview-size": "node scripts/e2e/run.mjs --test planning-preview-size",
    "test:e2e:planning-preview-size:firefox": "node scripts/e2e/run.mjs --browser firefox --test planning-preview-size",
    "test:e2e:planning-preview-size:chromium": "node scripts/e2e/run.mjs --browser chromium --test planning-preview-size",
    "test:e2e:planning-preview-zoom-sync": "node scripts/e2e/run.mjs --test planning-preview-zoom-sync",
    "test:e2e:planning-preview-zoom-sync:firefox": "node scripts/e2e/run.mjs --browser firefox --test planning-preview-zoom-sync",
    "test:e2e:planning-preview-zoom-sync:chromium": "node scripts/e2e/run.mjs --browser chromium --test planning-preview-zoom-sync",
    "check:archive:chromium": "npm run test:e2e:archive:chromium",
    "check:archive:firefox": "npm run test:e2e:archive:firefox"
  },
  "devDependencies": {
    "@types/archiver": "latest",
    "@types/node": "latest",
    "archiver": "^7.0.1",
    "esbuild": "^0.27.3",
    "selenium-webdriver": "^4.41.0",
    "typescript": "latest"
  },
  "engines": {
    "node": ">=18"
  }
}
